{
  "name": "server-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.app.json src/index.ts",
    "build": "tsc -p tsconfig.app.json && tsc-alias -p tsconfig.app.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "test": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.14",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
